class Solution {
    public int rob(int[] nums) {
        int num = nums.length;
        if (num == 0) return 0;
        if (num == 1) return nums[0];
        int[] dp = new int[num];
        dp[0] = nums[0];
        dp[1] = Math.max(nums[0], nums[1]); 
        for (int i = 2; i < num; i++) {
            dp[i] = Math.max(dp[i - 1], nums[i] + dp[i - 2]);
            System.out.println(dp[i]);
        }
        return dp[num - 1];
    }
}
