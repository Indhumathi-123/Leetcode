#include <stdlib.h>
#include <string.h>

char* intToRoman(int num) {
    // 1. Pre-define all possible patterns for each decimal place
    char* thousands[] = {"", "M", "MM", "MMM"};
    char* hundreds[]  = {"", "C", "CC", "CCC", "CD", "D", "DC", "DCC", "DCCC", "CM"};
    char* tens[]      = {"", "X", "XX", "XXX", "XL", "L", "LX", "LXX", "LXXX", "XC"};
    char* ones[]      = {"", "I", "II", "III", "IV", "V", "VI", "VII", "VIII", "IX"};

    // 2. Allocate exactly what we need (15 chars + 1 null terminator)
    char* res = (char*)malloc(16 * sizeof(char));
    
    // 3. Directly build the string by accessing the arrays
    // This is much faster than looping and checking values
    res[0] = '\0'; 
    strcpy(res, thousands[num / 1000]);
    strcat(res, hundreds[(num % 1000) / 100]);
    strcat(res, tens[(num % 100) / 10]);
    strcat(res, ones[num % 10]);

    return res;
}
