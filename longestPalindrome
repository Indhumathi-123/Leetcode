#include <string.h>
#include <stdlib.h>

char* longestPalindrome(char* s) {
    int n = strlen(s);
    if (n <= 1) return s;

    int start = 0, maxLen = 1;

    for (int i = 0; i < n; i++) {
        
        for (int j = 0; j <= 1; j++) {
            int l = i;
            int r = i + j;

           
            while (l >= 0 && r < n && s[l] == s[r]) {
                int currentLen = r - l + 1;
                if (currentLen > maxLen) {
                    start = l;
                    maxLen = currentLen;
                }
                l--;
                r++;
            }
        }
    }

   
    char* result = (char*)malloc((maxLen + 1) * sizeof(char));
    for (int i = 0; i < maxLen; i++) {
        result[i] = s[start + i];
    }
    result[maxLen] = '\0';

    return result;
}
